<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PDOff.ViewModels"
             xmlns:services="using:PDOff.Services"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="PDOff.Views.MergeView"
             x:DataType="vm:MergeViewModel">

    <UserControl.Styles>
        <Style Selector="UserControl.dragging">
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <Style Selector="UserControl.dragging Border.drop-zone">
            <Setter Property="BorderBrush" Value="#4CAF50"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="40,24" MaxWidth="700" HorizontalAlignment="Center">
            <!-- Title -->
            <TextBlock Text="{Binding [MergeTitle], Source={x:Static services:Lang.Instance}}" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="{Binding [MergeSubtitle], Source={x:Static services:Lang.Instance}}" Opacity="0.6"/>

            <!-- Add files -->
            <Button Command="{Binding AddFilesCommand}" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center" Padding="16,12" CornerRadius="8"
                    Classes="accent">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" Width="18" Height="18"/>
                    <TextBlock Text="{Binding [MergeAddFiles], Source={x:Static services:Lang.Instance}}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- File list -->
            <Border CornerRadius="8" Padding="4" MinHeight="150"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1"
                    IsVisible="{Binding Files.Count}"
                    DragDrop.AllowDrop="True"
                    Classes="drop-zone">
                <ListBox ItemsSource="{Binding Files}" SelectionMode="Single"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <DockPanel Margin="4,2">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                                    <Button Command="{Binding $parent[ListBox].((vm:MergeViewModel)DataContext).MoveUpCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{Binding [MoveUp], Source={x:Static services:Lang.Instance}}"
                                            Padding="6,4" Background="Transparent">
                                        <PathIcon Data="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z"
                                                  Width="14" Height="14"/>
                                    </Button>
                                    <Button Command="{Binding $parent[ListBox].((vm:MergeViewModel)DataContext).MoveDownCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{Binding [MoveDown], Source={x:Static services:Lang.Instance}}"
                                            Padding="6,4" Background="Transparent">
                                        <PathIcon Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"
                                                  Width="14" Height="14"/>
                                    </Button>
                                    <Button Command="{Binding $parent[ListBox].((vm:MergeViewModel)DataContext).RemoveFileCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{Binding [Remove], Source={x:Static services:Lang.Instance}}"
                                            Padding="6,4" Background="Transparent" Foreground="Red">
                                        <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                                  Width="14" Height="14"/>
                                    </Button>
                                </StackPanel>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Margin="8,0"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Empty state -->
            <Border CornerRadius="8" Padding="32" MinHeight="150"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1" IsVisible="{Binding !Files.Count}"
                    DragDrop.AllowDrop="True"
                    Classes="drop-zone">
                <TextBlock Text="{Binding [MergeEmptyState], Source={x:Static services:Lang.Instance}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Opacity="0.5" TextWrapping="Wrap" TextAlignment="Center"/>
            </Border>

            <!-- Merge button -->
            <Button Command="{Binding MergeCommand}" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center" Padding="16,14" CornerRadius="8"
                    FontSize="16" FontWeight="SemiBold">
                <TextBlock Text="{Binding [MergeButton], Source={x:Static services:Lang.Instance}}" VerticalAlignment="Center"/>
            </Button>

            <!-- Progress -->
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" Margin="0,4"/>

            <!-- Status message -->
            <Border CornerRadius="6" Padding="12,8" IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <Panel>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                               FontWeight="SemiBold" Foreground="#4CAF50"
                               IsVisible="{Binding IsSuccess}"/>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                               FontWeight="SemiBold" Foreground="#D32F2F"
                               IsVisible="{Binding !IsSuccess}"/>
                </Panel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
