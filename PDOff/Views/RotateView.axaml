<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PDOff.ViewModels"
             xmlns:services="using:PDOff.Services"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="PDOff.Views.RotateView"
             x:DataType="vm:RotateViewModel">

    <UserControl.Styles>
        <Style Selector="UserControl.dragging">
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <Style Selector="UserControl.dragging Button.drop-zone">
            <Setter Property="BorderBrush" Value="#4CAF50"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="40,24" MaxWidth="700" HorizontalAlignment="Center">
            <!-- Title -->
            <TextBlock Text="{Binding [RotateTitle], Source={x:Static services:Lang.Instance}}" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="{Binding [RotateSubtitle], Source={x:Static services:Lang.Instance}}" Opacity="0.6"/>

            <!-- File selection -->
            <Button Command="{Binding SelectFileCommand}" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center" Padding="16,12" CornerRadius="8"
                    Classes="accent drop-zone" DragDrop.AllowDrop="True">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11z"
                              Width="18" Height="18"/>
                    <TextBlock Text="{Binding [RotateSelectFile], Source={x:Static services:Lang.Instance}}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Selected file display -->
            <Border CornerRadius="6" Padding="12,8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    IsVisible="{Binding SelectedFile, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding SelectedFile}" TextTrimming="CharacterEllipsis" Opacity="0.8"/>
            </Border>

            <!-- Angle -->
            <TextBlock Text="{Binding [RotateAngleLabel], Source={x:Static services:Lang.Instance}}" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0"/>

            <StackPanel Spacing="10">
                <RadioButton GroupName="Angle"
                             Content="{Binding [Rotate90CW], Source={x:Static services:Lang.Instance}}"
                             IsChecked="{Binding Is90CW}"/>
                <RadioButton GroupName="Angle"
                             Content="{Binding [Rotate90CCW], Source={x:Static services:Lang.Instance}}"
                             IsChecked="{Binding Is90CCW}"/>
                <RadioButton GroupName="Angle"
                             Content="{Binding [Rotate180], Source={x:Static services:Lang.Instance}}"
                             IsChecked="{Binding Is180}"/>
            </StackPanel>

            <!-- Pages -->
            <TextBlock Text="{Binding [RotatePagesLabel], Source={x:Static services:Lang.Instance}}" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0"/>

            <StackPanel Spacing="10">
                <RadioButton GroupName="Pages"
                             Content="{Binding [RotateAllPages], Source={x:Static services:Lang.Instance}}"
                             IsChecked="{Binding AllPages}"/>
                <StackPanel Spacing="6">
                    <RadioButton GroupName="Pages"
                                 Content="{Binding [RotatePageRange], Source={x:Static services:Lang.Instance}}"
                                 IsChecked="{Binding !AllPages}"/>
                    <TextBox Text="{Binding PageRange}" Watermark="1-3, 5, 8-10"
                             Margin="28,0,0,0" Width="250" HorizontalAlignment="Left"
                             IsEnabled="{Binding !AllPages}"/>
                </StackPanel>
            </StackPanel>

            <!-- Apply button -->
            <Button Command="{Binding RotateCommand}" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center" Padding="16,14" CornerRadius="8"
                    FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0">
                <TextBlock Text="{Binding [RotateButton], Source={x:Static services:Lang.Instance}}"/>
            </Button>

            <!-- Progress -->
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" Margin="0,4"/>

            <!-- Status message -->
            <Border CornerRadius="6" Padding="12,8"
                    IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <Panel>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                               FontWeight="SemiBold" Foreground="#4CAF50"
                               IsVisible="{Binding IsSuccess}"/>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                               FontWeight="SemiBold" Foreground="#D32F2F"
                               IsVisible="{Binding !IsSuccess}"/>
                </Panel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
